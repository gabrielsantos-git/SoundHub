{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "nodeVersion": "20.x",
        "includeFiles": [
          "css/**",
          "assets/**",
          "*.html",
          "utils/**",
          "navigation.js",
          "sidebar.js",
          "project.js",
          "qrStore.js"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
