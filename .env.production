# Variáveis de Ambiente para Produção
NODE_ENV=production
PORT=3000

# Segurança
JWT_SECRET=soundhub-production-secret-key-change-this-in-production
DB_PATH=./database.sqlite

# Configurações do Servidor
HOST=0.0.0.0
CORS_ORIGIN=*

# Upload de Arquivos
MAX_FILE_SIZE=100MB
UPLOAD_DIR=./uploads

# QR Codes
QR_EXPIRY_TIME=3600000  # 1 hora em milissegundos
